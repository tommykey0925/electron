{
  "name": "Electron Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--net=host",
    "--security-opt", "seccomp=unconfined"
  ],
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "corepack enable && pnpm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
